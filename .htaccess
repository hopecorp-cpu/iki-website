# IKI by HOPE CORP — Apache config for AZDIGI hosting
# https://ikihealing.com

# ====================================================================
# 1. Force HTTPS (redirect HTTP → HTTPS sau khi cài SSL)
# ====================================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect HTTP to HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP_HOST} !=localhost
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Redirect www to non-www (chọn 1 canonical)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # Clean URLs — bỏ .html khi truy cập (ikihealing.com/hoc-vien thay vì /hoc-vien.html)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^([^/]+?)/?$ /$1.html [L]

  # Redirect .html → clean URL (canonical)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
</IfModule>

# ====================================================================
# 2. Custom 404 page
# ====================================================================
ErrorDocument 404 /404.html

# ====================================================================
# 3. Gzip compression (giảm dung lượng truyền tải)
# ====================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ====================================================================
# 4. Browser caching — tăng tốc trang
# ====================================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML: 1 giờ (cho phép update nội dung nhanh)
  ExpiresByType text/html "access plus 1 hour"

  # CSS, JS: 1 tuần
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType text/javascript "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"

  # Ảnh, font: 1 tháng
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"
  ExpiresByType font/woff "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 month"
</IfModule>

# ====================================================================
# 5. Security headers
# ====================================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ====================================================================
# 6. Disable directory listing (bảo mật)
# ====================================================================
Options -Indexes

# ====================================================================
# 7. Prevent access to sensitive files
# ====================================================================
<FilesMatch "^\.(htaccess|htpasswd|env|git)">
  Require all denied
</FilesMatch>
